{
  "name": "react-graph-ai",
  "displayName": "React Graph AI — Token-Slim AI Context for React",
  "description": "Prune your React/Next.js codebase to minimal AI context. Reduces LLM token usage by 90%+ for GitHub Copilot, Claude, ChatGPT, and any AI tool.",
  "version": "1.1.0",
  "publisher": "react-graph-ai",
  "license": "Apache-2.0",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["AI", "Other"],
  "keywords": ["react", "nextjs", "ai", "token", "copilot", "context", "graph"],
  "icon": "icon.png",
  "activationEvents": [
    "workspaceContains:**/*.tsx",
    "workspaceContains:**/*.jsx"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "react-graph-ai.copyContext",
        "title": "Copy AI Context (Token-Optimized)",
        "category": "React Graph AI"
      },
      {
        "command": "react-graph-ai.analyzeImpact",
        "title": "Analyze Component Impact",
        "category": "React Graph AI"
      },
      {
        "command": "react-graph-ai.rebuildGraph",
        "title": "Rebuild Graph Index",
        "category": "React Graph AI"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "react-graph-ai.copyContext",
          "when": "resourceExtname =~ /\\.(tsx|jsx|ts|js)$/",
          "group": "react-graph-ai@1"
        },
        {
          "command": "react-graph-ai.analyzeImpact",
          "when": "resourceExtname =~ /\\.(tsx|jsx|ts|js)$/",
          "group": "react-graph-ai@2"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krishteja18/react-graph-ai.git"
  },
  "homepage": "https://github.com/krishteja18/react-graph-ai#readme",
  "bugs": {
    "url": "https://github.com/krishteja18/react-graph-ai/issues"
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "vsce:package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.8.2"
  }
}
